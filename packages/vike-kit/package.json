{
  "name": "@bitcart/vike-kit",
  "version": "1.0.0",
  "description": "Shared Vike configuration and i18n setup for Bitcart applications",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle/index.d.ts",
      "import": "./dist/lifecycle/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata/index.d.ts",
      "import": "./dist/metadata/index.js"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "import": "./dist/navigation/index.js"
    },
    "./tracking": {
      "types": "./dist/tracking/index.d.ts",
      "import": "./dist/tracking/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "lint:check": "oxlint . --type-aware",
    "lint": "oxlint . --fix --type-aware",
    "generate:graphviz": "depcruise src --output-type dot | dot -T svg -o graphviz.svg",
    "generate:dist-graphviz": "depcruise dist --output-type dot | dot -T svg -o dist-graphviz.svg",
    "build": "tsdown"
  },
  "dependencies": {
    "@bitcart/core": "workspace:*",
    "@lingui/core": "catalog:dependencies",
    "@lingui/react": "catalog:dependencies",
    "@t3-oss/env-core": "catalog:dependencies",
    "lucide-react": "catalog:dependencies",
    "react": "catalog:dependencies",
    "remeda": "catalog:dependencies",
    "usehooks-ts": "catalog:dependencies",
    "vike": "catalog:dependencies",
    "vike-react": "catalog:dependencies",
    "vike-react-query": "catalog:dependencies",
    "zod": "catalog:dependencies"
  },
  "devDependencies": {
    "@bitcart/configs": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:devDependencies",
    "@types/react": "catalog:devDependencies",
    "dependency-cruiser": "catalog:devDependencies",
    "eslint-plugin-react-hooks": "catalog:devDependencies",
    "oxlint": "catalog:devDependencies",
    "tsdown": "catalog:devDependencies",
    "typescript": "catalog:devDependencies"
  }
}
