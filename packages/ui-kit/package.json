{
  "name": "@bitcart/ui-kit",
  "version": "1.1.0",
  "description": "UI development kit for applications and websites under the Bitcart umbrella",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "lint:check": "oxlint .",
    "lint": "oxlint . --fix",
    "shadcn-ui": "pnpm dlx shadcn@latest",
    "add:components": "pnpm shadcn-ui add -p ./src/components/tmp",
    "generate:graphviz": "depcruise src --output-type dot | ../../scripts/graphviz-postprocess.js | dot -T svg -o graphviz.svg",
    "build:styles": "unocss",
    "build:main": "tsdown"
  },
  "dependencies": {
    "@base-ui/react": "catalog:dependencies",
    "@bitcart/core": "workspace:*",
    "@lingui/core": "catalog:dependencies",
    "@phosphor-icons/react": "catalog:dependencies",
    "@tanstack/react-form": "catalog:dependencies",
    "babel-plugin-react-compiler": "catalog:devDependencies",
    "class-variance-authority": "catalog:dependencies",
    "lucide-react": "catalog:dependencies",
    "next-themes": "catalog:dependencies",
    "react": "catalog:dependencies",
    "react-day-picker": "catalog:dependencies",
    "remeda": "catalog:dependencies",
    "sonner": "catalog:dependencies",
    "tailwind-merge": "catalog:dependencies",
    "usehooks-ts": "catalog:dependencies"
  },
  "devDependencies": {
    "@bitcart/configs": "workspace:*",
    "@bitcart/qa": "workspace:*",
    "@bitcart/unocss-preset": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:devDependencies",
    "@types/node": "catalog:devDependencies",
    "@types/react": "catalog:devDependencies",
    "@unocss/cli": "catalog:devDependencies",
    "dependency-cruiser": "catalog:devDependencies",
    "eslint-plugin-better-tailwindcss": "catalog:devDependencies",
    "eslint-plugin-react-hooks": "catalog:devDependencies",
    "oxlint": "catalog:devDependencies",
    "tsdown": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "unocss": "catalog:devDependencies"
  }
}
