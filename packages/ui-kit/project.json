{
  "name": "@bitcart/ui-kit",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "build:styles": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/src/styles/uno.generated.css"],
      "cache": true
    },

    "build:main": {
      "dependsOn": ["build:styles", "^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },

    "build": {
      "dependsOn": ["build:main"]
    },

    "lint": {
      "dependsOn": ["build:styles", "^build", "^lint"]
    },

    "format": {
      "dependsOn": ["build:styles", "^build", "^format"]
    }
  }
}
