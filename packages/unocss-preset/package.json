{
  "name": "@bitcart/unocss-preset",
  "version": "1.0.0",
  "description": "UnoCSS preset for applications and websites under the Bitcart umbrella",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "lint:check": "oxlint .",
    "lint": "oxlint . --fix",
    "generate:graphviz": "depcruise src --output-type dot | dot -T svg -o graphviz.svg",
    "generate:dist-graphviz": "depcruise dist --output-type dot | dot -T svg -o dist-graphviz.svg",
    "build": "tsdown"
  },
  "dependencies": {},
  "devDependencies": {
    "@bitcart/configs": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:devDependencies",
    "@unocss/cli": "catalog:devDependencies",
    "@unocss/preset-wind4": "catalog:devDependencies",
    "dependency-cruiser": "catalog:devDependencies",
    "oxlint": "catalog:devDependencies",
    "tsdown": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "unocss": "catalog:devDependencies",
    "unocss-preset-animations": "catalog:devDependencies",
    "unocss-preset-shadcn": "catalog:devDependencies"
  }
}
