{
  "name": "@bitcart/unocss-preset",
  "version": "1.0.0",
  "description": "UnoCSS preset for applications and websites under the Bitcart umbrella",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "generate:graphviz": "madge --image graphviz.svg src",
    "generate:dist-graphviz": "madge --image dist-graphviz.svg dist",
    "build": "vite build"
  },
  "dependencies": {},
  "devDependencies": {
    "@bitcart/typescript-config": "workspace:*",
    "@unocss/cli": "catalog:devDependencies",
    "@unocss/preset-wind4": "catalog:devDependencies",
    "madge": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "unocss": "catalog:devDependencies",
    "unocss-preset-animations": "catalog:devDependencies",
    "unocss-preset-shadcn": "catalog:devDependencies",
    "unplugin-dts": "catalog:devDependencies",
    "vite": "catalog:devDependencies",
    "vite-plugin-externalize-deps": "catalog:devDependencies",
    "vite-tsconfig-paths": "catalog:devDependencies"
  },
  "madge": {
    "fileExtensions": [
      "js",
      "ts"
    ],
    "tsConfig": "tsconfig.json",
    "layout": "dot",
    "fontSize": "16px",
    "graphVizOptions": {
      "compound": true
    }
  }
}
