{
  "name": "@bitcart/form-kit",
  "version": "1.0.0",
  "description": "Form development kit for applications and websites under the Bitcart umbrella",
  "type": "module",
  "exports": {
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "generate:graphviz": "madge --image graphviz.svg src",
    "build": "vite build"
  },
  "dependencies": {
    "@bitcart/core": "workspace:*",
    "@bitcart/ui-kit": "workspace:*",
    "@tanstack/react-form": "catalog:dependencies",
    "class-variance-authority": "catalog:dependencies",
    "lucide-react": "catalog:dependencies",
    "react": "catalog:dependencies",
    "remeda": "catalog:dependencies",
    "usehooks-ts": "catalog:dependencies"
  },
  "devDependencies": {
    "@bitcart/typescript-config": "workspace:*",
    "@types/react": "catalog:devDependencies",
    "@vitejs/plugin-react": "catalog:devDependencies",
    "madge": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "unplugin-dts": "catalog:devDependencies",
    "vite": "catalog:devDependencies",
    "vite-plugin-externalize-deps": "catalog:devDependencies",
    "vite-tsconfig-paths": "catalog:devDependencies"
  },
  "madge": {
    "fileExtensions": [
      "js",
      "ts",
      "tsx"
    ],
    "tsConfig": "tsconfig.json",
    "layout": "dot",
    "fontSize": "16px",
    "graphVizOptions": {
      "compound": true
    }
  }
}
