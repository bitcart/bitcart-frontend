{
  "name": "@bitcart/form-kit",
  "version": "1.0.0",
  "description": "Form development kit for applications and websites under the Bitcart umbrella",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "lint:check": "oxlint .",
    "lint": "oxlint . --fix",
    "generate:graphviz": "depcruise src --output-type dot | dot -T svg -o graphviz.svg",
    "build": "tsdown"
  },
  "dependencies": {
    "@bitcart/core": "workspace:*",
    "@bitcart/ui-kit": "workspace:*",
    "@tanstack/react-form": "catalog:dependencies",
    "react": "catalog:dependencies",
    "remeda": "catalog:dependencies"
  },
  "devDependencies": {
    "@bitcart/configs": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:devDependencies",
    "@types/node": "catalog:devDependencies",
    "@types/react": "catalog:devDependencies",
    "dependency-cruiser": "catalog:devDependencies",
    "eslint-plugin-react-hooks": "catalog:devDependencies",
    "oxlint": "catalog:devDependencies",
    "tsdown": "catalog:devDependencies",
    "typescript": "catalog:devDependencies"
  }
}
