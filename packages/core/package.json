{
  "name": "@bitcart/core",
  "version": "1.0.0",
  "description": "Foundational abstractions for packages, applications, and websites under the Bitcart umbrella.",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./constants": {
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./zod": {
      "import": "./dist/zod/index.js",
      "types": "./dist/zod/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "lint:check": "oxlint .",
    "lint": "oxlint . --fix",
    "generate:graphviz": "depcruise src --output-type dot | dot -T svg -o graphviz.svg",
    "generate:dist-graphviz": "depcruise dist --output-type dot | dot -T svg -o dist-graphviz.svg",
    "build": "tsdown"
  },
  "dependencies": {
    "remeda": "catalog:dependencies",
    "usehooks-ts": "catalog:dependencies",
    "zod": "catalog:dependencies"
  },
  "devDependencies": {
    "@bitcart/configs": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:devDependencies",
    "@types/node": "catalog:devDependencies",
    "dependency-cruiser": "catalog:devDependencies",
    "oxlint": "catalog:devDependencies",
    "tsdown": "catalog:devDependencies",
    "typescript": "catalog:devDependencies"
  }
}
