{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "autoExit": true
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/.env"],
    "oxlintInputs": ["default", "{workspaceRoot}/oxlint.config.ts"]
  },
  "targetDefaults": {
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "cache": true
    },

    "lint:check": {
      "dependsOn": ["^build", "^lint:check"],
      "inputs": ["oxlintInputs"],
      "cache": true
    },

    "lint": {
      "dependsOn": ["^build", "^lint"],
      "inputs": ["oxlintInputs"],
      "cache": true
    },

    "dev": {
      "cache": false,
      "continuous": true
    },

    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },

    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "continuous": true
    }
  },
  "defaultBase": "master"
}
