{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "autoExit": true
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "buildInputs": ["default", "!{projectRoot}/e2e/**", "!{projectRoot}/playwright.config.ts"],
    "sharedGlobals": ["{workspaceRoot}/.env", { "env": "BITCART_ENV" }],
    "oxlintInputs": ["default", "{workspaceRoot}/oxlint.config.ts"]
  },
  "targetDefaults": {
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "cache": true
    },

    "lint:check": {
      "dependsOn": ["^build", "^lint:check"],
      "inputs": ["oxlintInputs", "^default"],
      "cache": true
    },

    "lint": {
      "dependsOn": ["^build", "^lint"],
      "inputs": ["oxlintInputs", "^default"],
      "cache": true
    },

    "dev": {
      "cache": false,
      "continuous": true
    },

    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },

    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "continuous": true
    },

    "i18n:extract-locales": {
      "dependsOn": ["^build"],
      "inputs": ["buildInputs", "^default"],
      "outputs": ["{projectRoot}/src/common/i18n/_generated"],
      "cache": true
    },

    "e2e": {
      "dependsOn": ["build"],
      "cache": false
    }
  },
  "defaultBase": "master",
  "analytics": false
}
