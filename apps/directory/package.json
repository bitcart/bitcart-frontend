{
  "name": "@bitcart/directory",
  "version": "1.0.0",
  "description": "Directory of apps, hosting providers, and merchants using Bitcart for cryptocurrency payments",
  "author": "MrNaif2018",
  "type": "module",
  "scripts": {
    "i18n:extract-locales": "lingui extract --clean",
    "generate:graphviz": "depcruise src --output-type dot | dot -T svg -o graphviz.svg",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint:check": "oxlint .",
    "lint": "oxlint . --fix",
    "build:styles": "unocss",
    "build:main": "vike build",
    "dev:styles": "unocss --watch",
    "dev:main": "vike dev --host",
    "preview": "vike preview --host --port 3001",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "release": "../../scripts/release-static-site.sh directory"
  },
  "dependencies": {
    "@bitcart/core": "workspace:*",
    "@bitcart/form-kit": "workspace:*",
    "@bitcart/ui-kit": "workspace:*",
    "@bitcart/vike-kit": "workspace:*",
    "@lingui/core": "catalog:dependencies",
    "@lingui/react": "catalog:dependencies",
    "@phosphor-icons/react": "catalog:dependencies",
    "@t3-oss/env-core": "catalog:dependencies",
    "@tanstack/react-form": "catalog:dependencies",
    "@tanstack/react-query": "catalog:dependencies",
    "class-variance-authority": "catalog:dependencies",
    "dotenv": "catalog:dependencies",
    "effect": "catalog:dependencies",
    "inter-ui": "catalog:dependencies",
    "lucide-react": "catalog:dependencies",
    "react": "catalog:dependencies",
    "react-dom": "catalog:dependencies",
    "remeda": "catalog:dependencies",
    "usehooks-ts": "catalog:dependencies",
    "vike": "catalog:dependencies",
    "vike-react": "catalog:dependencies",
    "vike-react-query": "catalog:dependencies",
    "zod": "catalog:dependencies"
  },
  "devDependencies": {
    "@bitcart/configs": "workspace:*",
    "@bitcart/qa": "workspace:*",
    "@bitcart/unocss-preset": "workspace:*",
    "@lingui/babel-plugin-lingui-macro": "catalog:devDependencies",
    "@lingui/cli": "catalog:devDependencies",
    "@lingui/conf": "catalog:devDependencies",
    "@lingui/vite-plugin": "catalog:devDependencies",
    "@playwright/test": "catalog:devDependencies",
    "@qalisa/vike-plugin-sitemap": "catalog:devDependencies",
    "@rolldown/plugin-babel": "catalog:devDependencies",
    "@stylistic/eslint-plugin": "catalog:devDependencies",
    "@types/node": "catalog:devDependencies",
    "@types/react": "catalog:devDependencies",
    "@types/react-dom": "catalog:devDependencies",
    "@unocss/cli": "catalog:devDependencies",
    "@vitejs/plugin-react": "catalog:devDependencies",
    "babel-plugin-react-compiler": "catalog:devDependencies",
    "dependency-cruiser": "catalog:devDependencies",
    "eslint-plugin-better-tailwindcss": "catalog:devDependencies",
    "eslint-plugin-react-hooks": "catalog:devDependencies",
    "oxlint": "catalog:devDependencies",
    "typescript": "catalog:devDependencies",
    "unocss": "catalog:devDependencies",
    "vite": "catalog:devDependencies",
    "vite-plugin-static-copy": "catalog:devDependencies"
  }
}
