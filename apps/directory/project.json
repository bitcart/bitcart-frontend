{
  "name": "@bitcart/directory",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "build:styles": {
      "dependsOn": ["^build"],
      "inputs": ["buildInputs", "^default"],
      "outputs": ["{projectRoot}/src/pages/uno.generated.css"],
      "cache": true
    },

    "build:main": {
      "dependsOn": ["build:styles", "i18n:extract-locales", "^build"],
      "inputs": [
        "buildInputs",
        "^default",
        { "runtime": "grep '^BITCART_' .env 2>/dev/null | sort" }
      ],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },

    "build": {
      "dependsOn": ["build:main"]
    },

    "build-deps": {
      "dependsOn": ["^build"]
    },

    "watch-deps": {
      "continuous": true,
      "dependsOn": ["build-deps"],
      "command": "pnpm nx watch --projects @bitcart/directory --includeDependentProjects -- pnpm nx build-deps @bitcart/directory"
    },

    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["pnpm dev:styles", "pnpm dev:main"],
        "parallel": true,
        "cwd": "apps/directory"
      },
      "dependsOn": ["i18n:extract-locales", "watch-deps"],
      "continuous": true
    },

    "lint:check": {
      "dependsOn": ["build:styles", "^build", "^lint:check"]
    },

    "lint": {
      "dependsOn": ["build:styles", "^build", "^lint"]
    }
  }
}
